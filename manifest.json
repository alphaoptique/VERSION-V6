{
  "manifest_version": 3,
  "name": "Always Open PDFs Smart",
  "version": "6.0",
  "description": "Smart PDF opener (realistic mode)",

  "permissions": [
    "tabs",
    "scripting"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "background": {
    "service_worker": "service-worker.js"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
}
